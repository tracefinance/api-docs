{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Trace Finance",
  "colors": {
    "primary": "#15803D",
    "light": "#18E299",
    "dark": "#0C8C5E"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://tracefinance.io"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "gradient"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": "tokyo-night"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "guides/authentication",
              "guides/environments"
            ]
          },
          {
            "group": "API principles",
            "pages": [
              "guides/principles/versioning",
              "guides/principles/idempotency",
              "guides/principles/pagination",
              "guides/principles/filtering",
              "guides/principles/money",
              "guides/principles/datetime",
              "guides/principles/errors"
            ]
          },
          {
            "group": "Journeys",
            "pages": [
              "journeys/open-brl-account",
              "journeys/open-crypto-account",
              "journeys/deposit",
              "journeys/withdrawal",
              "journeys/swap"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "href": "https://status.tracefinance.io",
          "icon": "signal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@tracefinance.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "api": {
    "baseUrl": [
      "https://faas.sandbox.tracefinance.io",
      "https://faas.tracefinance.io"
    ],
    "auth": {
      "method": "bearer"
    }
  },
  "description": "Explore guides, examples, and API references to build with Trace Finance.",
  "variables": {
    "sandboxUrl": "https://faas.sandbox.tracefinance.io",
    "productionUrl": "https://faas.tracefinance.io",
    "authUrl": "https://auth.tracefinance.io"
  },
  "seo": {
    "indexing": "navigable"
  },
  "search": {
    "placeholder": "Search docs..."
  },
  "metadata": {
    "lastUpdatedDate": true
  },
  "footer": {
    "socials": {
      "github": "https://github.com/tracefinance",
      "linkedin": "https://linkedin.com/company/tracefinance"
    }
  }
}
