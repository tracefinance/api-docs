{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Trace Finance Developer Docs",
  "colors": {
    "primary": "#15803D",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "guides/authentication",
              "guides/environments"
            ]
          },
          {
            "group": "API principles",
            "pages": [
              "guides/principles/versioning",
              "guides/principles/idempotency",
              "guides/principles/pagination",
              "guides/principles/money",
              "guides/principles/errors"
            ]
          },
          {
            "group": "Journeys",
            "pages": [
              "journeys/open-brl-account",
              "journeys/open-crypto-account",
              "journeys/deposit",
              "journeys/withdrawal",
              "journeys/swap"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/events"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "href": "https://status.tracefinance.io",
          "icon": "signal"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@tracefinance.io"
      }
    ]
  },
  "api": {
    "baseUrl": [
      "https://faas.sandbox.tracefinance.io",
      "https://faas.tracefinance.io"
    ],
    "auth": {
      "method": "bearer"
    }
  },
  "description": "API documentation for Trace Finance's multi-currency account and payment platform.",
  "seo": {
    "indexing": "navigable"
  },
  "search": {
    "placeholder": "Search docs..."
  },
  "metadata": {
    "lastUpdatedDate": true
  },
  "footer": {
    "socials": {
      "github": "https://github.com/tracefinance",
      "linkedin": "https://linkedin.com/company/tracefinance"
    }
  }
}
